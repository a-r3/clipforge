# ============================================================
# ClipForge — example environment configuration
# Copy this file to .env and fill in the values you need.
# Lines starting with # are comments; they are ignored.
# ============================================================

# ── Stock media providers (optional) ────────────────────────
# Get a free key at https://www.pexels.com/api/
PEXELS_API_KEY=

# Get a free key at https://pixabay.com/api/docs/
PIXABAY_API_KEY=

# ── AI provider (optional) ───────────────────────────────────
# Set to off, openai, anthropic, or gemini
AI_PROVIDER=off
AI_MODEL=

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── YouTube publishing (optional) ────────────────────────────
# Path to Google credentials JSON (service account or OAuth2 token).
# Required for: clipforge publish execute  (YouTube uploads)
# Required for: clipforge analytics fetch  (YouTube Analytics API)
# See docs/publish.md for credential setup instructions.
YOUTUBE_CREDENTIALS_PATH=

# ── Publish safety overrides (optional) ──────────────────────
# Set to 1 to default all publish calls to dry-run mode.
# Useful for staging/CI environments.
CLIPFORGE_PUBLISH_DRY_RUN=

# Override the default publish provider (default: manual).
# Set to "youtube" to use the YouTube provider when available.
CLIPFORGE_DEFAULT_PROVIDER=
